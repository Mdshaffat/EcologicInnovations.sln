{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=EcologicInnovationsDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Seed": {
    "ApplyMigrationsOnStartup": true,
    "SeedCoreContent": true,
    "SeedCategories": true,
    "SeedSampleCatalogContent": true,
    "SeedAdminUserAndRole": true,
    "DefaultAdminEmail": "admin@ecologicinnovations.local",
    "DefaultAdminPassword": "Admin@12345"
  },
  "Seo": {
    "BaseUrl": "https://localhost:5001"
  },
  "SiteRuntime": {
    "IncludeUnpublishedInSitemap": false,
    "DisallowAdminInRobots": true,
    "DisallowAccountPagesInRobots": true
  }
}
