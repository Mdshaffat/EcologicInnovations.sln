@using EcologicInnovations.Web.ViewModels.Shared

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <partial name="_SeoHead" />
    <partial name="_HtmlTypographyStylesPartial" />
    <partial name="_PublicStylesPartial" />
    @RenderSection("Styles", required: false)
    <!-- Google AdSense loader (place your publisher ID here) -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3600494668304950"
            crossorigin="anonymous"></script>
</head>
<body class="public-body">
    <header>
        @await Component.InvokeAsync("PublicNavigation")
    </header>

    <main class="public-main py-4">
        <div class="container">
            <partial name="_PublicAlerts" />
        </div>

        @RenderBody()
    </main>

    @await Component.InvokeAsync("PublicFooter")
    <partial name="_PublicToastContainer" />
    <partial name="_PublicScriptsPartial" />
    @RenderSection("Scripts", required: false)
</body>
</html>
