@using EcologicInnovations.Web.ViewModels.Shared
@using EcologicInnovations.Web.Helpers

@{
    var seo = ViewData.GetSeoMeta() ?? new SeoMetaViewModel();

    var title = string.IsNullOrWhiteSpace(seo.Title)
        ? "Ecologic Innovations"
        : seo.Title;

    var description = string.IsNullOrWhiteSpace(seo.Description)
        ? "Ecologic Innovations builds custom software, smart systems, training programs, and impact-driven technology for businesses and communities."
        : seo.Description;

    var canonical = seo.CanonicalUrl;
    var ogTitle = string.IsNullOrWhiteSpace(seo.OgTitle) ? title : seo.OgTitle;
    var ogDescription = string.IsNullOrWhiteSpace(seo.OgDescription) ? description : seo.OgDescription;
    var ogImage = seo.OgImageUrl;
    var ogType = string.IsNullOrWhiteSpace(seo.OgType) ? "website" : seo.OgType;
    var robots = string.IsNullOrWhiteSpace(seo.Robots) ? "index,follow" : seo.Robots;
}

<title>@title</title>
<meta name="description" content="@description" />
<meta name="robots" content="@robots" />

@if (!string.IsNullOrWhiteSpace(canonical))
{
    <link rel="canonical" href="@canonical" />
}

<meta property="og:title" content="@ogTitle" />
<meta property="og:description" content="@ogDescription" />
<meta property="og:type" content="@ogType" />

@if (!string.IsNullOrWhiteSpace(canonical))
{
    <meta property="og:url" content="@canonical" />
}

@if (!string.IsNullOrWhiteSpace(ogImage))
{
    <meta property="og:image" content="@ogImage" />
}

<partial name="_SchemaMarkup" />
