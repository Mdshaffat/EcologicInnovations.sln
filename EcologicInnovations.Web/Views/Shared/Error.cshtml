@*
    Fallback error view. The primary error handling flows through ErrorController
    and its dedicated views (Views/Error/Error.cshtml, Views/Error/NotFound.cshtml).
    This file exists as a safety net if a view render itself triggers an error.
*@

@{
    ViewData["Title"] = "Error";
}

<section class="status-page-shell py-5">
    <div class="container">
        <div class="status-page-card p-4 p-lg-5 text-center mx-auto" style="max-width: 760px;">
            <div class="status-page-icon mb-4">
                <i class="bi bi-exclamation-octagon"></i>
            </div>

            <div class="text-uppercase small fw-semibold text-secondary mb-2">
                Unexpected Error
            </div>

            <h1 class="display-6 fw-bold mb-3">Something went wrong</h1>

            <p class="lead text-secondary mb-4">
                We encountered an unexpected problem. Please try again in a moment or return to the home page.
            </p>

            <div class="d-flex flex-wrap justify-content-center gap-2">
                <a href="/" class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-house-door me-1"></i> Go to Home Page
                </a>
                <a href="/contact" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-envelope me-1"></i> Contact Support
                </a>
            </div>
        </div>
    </div>
</section>
