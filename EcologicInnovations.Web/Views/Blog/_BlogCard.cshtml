@model EcologicInnovations.Web.ViewModels.Blog.BlogCardViewModel
@using EcologicInnovations.Web.ViewModels.Shared

<div class="card h-100 border-0 shadow-sm blog-card">
    <a asp-controller="Blog" asp-action="Details" asp-route-slug="@Model.Slug" class="text-decoration-none text-reset">
        <div class="ratio ratio-16x9 blog-card-image-wrap bg-light">
            @if (!string.IsNullOrWhiteSpace(Model.FeatureImageUrl))
            {
                <img asp-smart-image="true"
                     src="@Model.FeatureImageUrl"
                     alt="@Model.Title"
                     class="w-100 h-100 object-fit-cover rounded-top" />
            }
            else
            {
                <partial name="_ImagePlaceholder"
                         model='new ImagePlaceholderViewModel
                         {
                             Title = "No article image",
                             Subtitle = "Feature image can be added later",
                             IconCssClass = "bi bi-journal-richtext",
                             WrapperCssClass = "h-100 rounded-top"
                         }' />
            }
        </div>
    </a>

    <div class="card-body d-flex flex-column">
        <div class="d-flex flex-wrap gap-2 mb-2 align-items-center">
            @if (!string.IsNullOrWhiteSpace(Model.CategoryName))
            {
                <span class="badge text-bg-light border">@Model.CategoryName</span>
            }

            @if (Model.PublishedAt.HasValue)
            {
                <span class="small text-secondary">@Model.PublishedAt.Value.ToString("dd MMM yyyy")</span>
            }
        </div>

        <h3 class="h6 fw-bold mb-2">
            <a asp-controller="Blog"
               asp-action="Details"
               asp-route-slug="@Model.Slug"
               class="text-decoration-none text-dark">
                @Model.Title
            </a>
        </h3>

        @if (!string.IsNullOrWhiteSpace(Model.Excerpt))
        {
            <p class="text-secondary small mb-3 flex-grow-1 blog-card-excerpt">
                @Model.Excerpt
            </p>
        }
        else
        {
            <div class="flex-grow-1"></div>
        }

        <div class="mt-auto">
            <a asp-controller="Blog"
               asp-action="Details"
               asp-route-slug="@Model.Slug"
               class="btn btn-outline-primary btn-sm rounded-pill px-3">
                Read More
            </a>
        </div>
    </div>
</div>
