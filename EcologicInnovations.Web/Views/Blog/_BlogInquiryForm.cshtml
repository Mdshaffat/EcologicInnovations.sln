@model EcologicInnovations.Web.ViewModels.Contact.ContactFormInputModel

<div class="blog-inquiry-form card border-0 shadow-sm rounded-4">
    <div class="card-body p-4 p-lg-5">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <input asp-for="SourceType" type="hidden" />
        <input asp-for="BlogPostId" type="hidden" />
        <input asp-for="SourceTitle" type="hidden" />
        <input asp-for="PageUrl" type="hidden" />

        <div class="mb-3">
            <label asp-for="RegardingBlogTitle" class="form-label fw-semibold"></label>
            <input asp-for="RegardingBlogTitle" class="form-control" readonly />
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Phone" class="form-label fw-semibold"></label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Company" class="form-label fw-semibold"></label>
                <input asp-for="Company" class="form-control" />
                <span asp-validation-for="Company" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Subject" class="form-label fw-semibold"></label>
                <input asp-for="Subject" class="form-control" />
                <span asp-validation-for="Subject" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Message" class="form-label fw-semibold"></label>
                <textarea asp-for="Message" class="form-control" rows="6"></textarea>
                <span asp-validation-for="Message" class="text-danger small"></span>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary rounded-pill px-4">
                Send Message
            </button>
        </div>
    </div>
</div>
