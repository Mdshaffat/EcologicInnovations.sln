@model EcologicInnovations.Web.ViewModels.Contact.ContactFormInputModel

<form asp-controller="Products"
      asp-action="SendInquiry"
      asp-route-slug="@ViewContext.RouteData.Values["slug"]"
      method="post"
      novalidate>
    @Html.AntiForgeryToken()

    <input asp-for="SourceType" type="hidden" />
    <input asp-for="ProductId" type="hidden" />
    <input asp-for="BlogPostId" type="hidden" />
    <input asp-for="SourceTitle" type="hidden" />
    <input asp-for="PageUrl" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="row g-3">
        <div class="col-12">
            <label asp-for="RegardingProductTitle" class="form-label"></label>
            <input asp-for="RegardingProductTitle" class="form-control" readonly />
        </div>

        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Phone" class="form-label"></label>
            <input asp-for="Phone" class="form-control" />
            <span asp-validation-for="Phone" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Company" class="form-label"></label>
            <input asp-for="Company" class="form-control" />
            <span asp-validation-for="Company" class="text-danger small"></span>
        </div>

        <div class="col-12">
            <label asp-for="Subject" class="form-label"></label>
            <input asp-for="Subject" class="form-control" placeholder="Optional subject" />
            <span asp-validation-for="Subject" class="text-danger small"></span>
        </div>

        <div class="col-12">
            <label asp-for="Message" class="form-label"></label>
            <textarea asp-for="Message" class="form-control" rows="6" placeholder="Write your question or requirement here..."></textarea>
            <span asp-validation-for="Message" class="text-danger small"></span>
        </div>

        <div class="col-12 d-flex flex-wrap gap-2 pt-2">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-send me-1"></i> Send Message
            </button>

            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">
                Back to Products
            </a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
