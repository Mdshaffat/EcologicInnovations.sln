@model EcologicInnovations.Web.ViewModels.Shared.ErrorPageViewModel

@{
    ViewData["Title"] = ViewData["Title"] ?? Model.Title ?? "Error";
}

@section Styles {
    <style>
        .error-tips { text-align: left; max-width: 420px; margin: 0 auto; }
        .error-tips li { padding: 0.25rem 0; }
    </style>
}

<section class="status-page-shell py-5">
    <div class="container">
        <div class="status-page-card p-4 p-lg-5 text-center mx-auto" style="max-width: 760px;">
            <div class="status-page-icon mb-4">
                <i class="@Model.IconCssClass"></i>
            </div>

            @if (Model.StatusCode.HasValue)
            {
                <div class="text-uppercase small fw-semibold text-secondary mb-2 tracking-wide">
                    Error @Model.StatusCode
                </div>
            }

            <h1 class="display-6 fw-bold mb-3">@Model.Title</h1>

            @if (!string.IsNullOrWhiteSpace(Model.Message))
            {
                <p class="lead text-secondary mb-4">
                    @Model.Message
                </p>
            }

            <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
                @if (!string.IsNullOrWhiteSpace(Model.PrimaryButtonText) && !string.IsNullOrWhiteSpace(Model.PrimaryButtonUrl))
                {
                    <a href="@Model.PrimaryButtonUrl" class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-house-door me-1"></i> @Model.PrimaryButtonText
                    </a>
                }

                @if (!string.IsNullOrWhiteSpace(Model.SecondaryButtonText) && !string.IsNullOrWhiteSpace(Model.SecondaryButtonUrl))
                {
                    <a href="@Model.SecondaryButtonUrl" class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="bi bi-envelope me-1"></i> @Model.SecondaryButtonText
                    </a>
                }
            </div>

            <hr class="mx-auto" style="max-width: 200px;" />

            <div class="mt-3">
                <p class="small text-muted fw-semibold mb-2">Here are a few things you can try:</p>
                <ul class="list-unstyled small text-muted error-tips">
                    <li><i class="bi bi-arrow-clockwise me-1"></i> Refresh this page</li>
                    <li><i class="bi bi-arrow-left me-1"></i> Go back to the previous page</li>
                    <li><i class="bi bi-house-door me-1"></i> Start fresh from our home page</li>
                </ul>
            </div>
        </div>
    </div>
</section>
