@model EcologicInnovations.Web.ViewModels.Admin.MediaUploadInputModel

<div class="card border-0 shadow-sm admin-upload-card">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div>
                <h2 class="h5 mb-1">Upload Media</h2>
                <p class="text-muted mb-0">Upload one or many files, then reuse the URL or HTML snippet in your content.</p>
            </div>
        </div>

        <form asp-area="Admin" asp-controller="Media" asp-action="Upload" method="post" enctype="multipart/form-data" class="row g-3">
            @Html.AntiForgeryToken()

            <div class="col-12">
                <label asp-for="Files" class="form-label fw-semibold"></label>
                <input asp-for="Files" class="form-control" type="file" multiple accept=".jpg,.jpeg,.png,.webp,.gif,.pdf" />
                <span asp-validation-for="Files" class="text-danger small"></span>
                <div class="form-text">You can select multiple files in one upload.</div>
            </div>

            <div class="col-md-4">
                <label asp-for="MediaGroup" class="form-label fw-semibold"></label>
                <input asp-for="MediaGroup" class="form-control" placeholder="Example: Product, Blog, Banner" />
                <span asp-validation-for="MediaGroup" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Title" class="form-label fw-semibold"></label>
                <input asp-for="Title" class="form-control" placeholder="Optional default title" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="AltText" class="form-label fw-semibold"></label>
                <input asp-for="AltText" class="form-control" placeholder="Optional default alt text" />
                <span asp-validation-for="AltText" class="text-danger small"></span>
            </div>

            <div class="col-12 d-flex justify-content-end">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-upload me-1"></i> Upload Files
                </button>
            </div>
        </form>
    </div>
</div>
