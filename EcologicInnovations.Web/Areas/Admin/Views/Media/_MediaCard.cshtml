@model EcologicInnovations.Web.ViewModels.Admin.MediaLibraryItemViewModel

<div class="col-12 col-sm-6 col-xl-4">
    <div class="card border-0 shadow-sm media-card h-100">
        <div class="media-card-preview">
            @if (Model.IsImage)
            {
                <img src="@Model.PublicUrl" alt="@(Model.AltText ?? Model.Title ?? Model.FileName)" class="media-card-image" />
            }
            else
            {
                <div class="media-card-file-icon d-flex align-items-center justify-content-center h-100">
                    <div class="text-center text-muted">
                        <i class="bi bi-file-earmark-text display-5"></i>
                        <div class="fw-semibold mt-2">@Model.ContentType</div>
                    </div>
                </div>
            }
        </div>

        <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                <div>
                    <h3 class="h6 mb-1 text-break">@(Model.Title ?? Model.FileName)</h3>
                    <div class="small text-muted text-break">@Model.FileName</div>
                </div>

                @if (Model.IsActive)
                {
                    <span class="badge rounded-pill text-bg-success">Active</span>
                }
                else
                {
                    <span class="badge rounded-pill text-bg-secondary">Inactive</span>
                }
            </div>

            <dl class="row small mb-3">
                <dt class="col-4 text-muted">Group</dt>
                <dd class="col-8 mb-2">@(Model.MediaGroup ?? "—")</dd>

                <dt class="col-4 text-muted">Alt</dt>
                <dd class="col-8 mb-2 text-break">@(Model.AltText ?? "—")</dd>

                <dt class="col-4 text-muted">Size</dt>
                <dd class="col-8 mb-2">@Model.FileSizeText</dd>

                <dt class="col-4 text-muted">Uploaded</dt>
                <dd class="col-8 mb-0">@Model.UploadedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</dd>
            </dl>

            <div class="mb-3">
                <label class="form-label small fw-semibold mb-1">Public URL</label>
                <input type="text" class="form-control form-control-sm" value="@Model.PublicUrl" readonly />
            </div>

            @if (Model.IsImage && !string.IsNullOrWhiteSpace(Model.CopyHtmlSnippet))
            {
                <div class="mb-3">
                    <label class="form-label small fw-semibold mb-1">Copy HTML</label>
                    <textarea class="form-control form-control-sm media-html-box" rows="3" readonly>@Model.CopyHtmlSnippet</textarea>
                </div>
            }

            <div class="mt-auto d-flex flex-wrap gap-2">
                <button type="button"
                        class="btn btn-outline-primary btn-sm js-copy-text"
                        data-copy-text="@Model.PublicUrl">
                    <i class="bi bi-link-45deg me-1"></i> Copy URL
                </button>

                @if (Model.IsImage && !string.IsNullOrWhiteSpace(Model.CopyHtmlSnippet))
                {
                    <button type="button"
                            class="btn btn-outline-success btn-sm js-copy-text"
                            data-copy-text="@Model.CopyHtmlSnippet">
                        <i class="bi bi-code-slash me-1"></i> Copy HTML
                    </button>
                }

                <a asp-area="Admin" asp-controller="Media" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-pencil-square me-1"></i> Edit
                </a>

                <form asp-area="Admin" asp-controller="Media" asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline"
                      onsubmit="return confirm('Delete this media item permanently?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-trash me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
