@model EcologicInnovations.Web.ViewModels.Admin.ProductAdminEditViewModel

<form asp-area="Admin" asp-controller="Products" asp-action="Create" method="post" novalidate>
    @Html.AntiForgeryToken()

    <partial name="_ProductForm" model="Model" />

    <div class="d-flex flex-wrap gap-2 mt-4">
        <button type="submit" class="btn btn-success px-4">
            <i class="bi bi-check2-circle me-1"></i> Save Product
        </button>
        <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">
            Cancel
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
