@model EcologicInnovations.Web.ViewModels.Admin.ProductAdminDetailsViewModel

<div class="card border-0 shadow-sm admin-card">
    <div class="card-body p-4 p-xl-5">
        <div class="alert alert-warning border-0">
            <div class="fw-semibold mb-1">Delete Confirmation</div>
            <div>Are you sure you want to delete this product? This action cannot be undone.</div>
        </div>

        <div class="row g-4">
            <div class="col-12 col-lg-8">
                <h2 class="h4 mb-3">@Model.Title</h2>

                <dl class="row mb-0">
                    <dt class="col-sm-4">Slug</dt>
                    <dd class="col-sm-8">@Model.Slug</dd>

                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8">@Model.CategoryName</dd>

                    <dt class="col-sm-4">Published</dt>
                    <dd class="col-sm-8">@(Model.IsPublished ? "Yes" : "No")</dd>

                    <dt class="col-sm-4">Active</dt>
                    <dd class="col-sm-8">@(Model.IsActive ? "Yes" : "No")</dd>

                    <dt class="col-sm-4">Featured</dt>
                    <dd class="col-sm-8">@(Model.IsFeatured ? "Yes" : "No")</dd>

                    <dt class="col-sm-4">Shown In Menu</dt>
                    <dd class="col-sm-8">@(Model.ShowInProductMenu ? "Yes" : "No")</dd>

                    <dt class="col-sm-4">Short Description</dt>
                    <dd class="col-sm-8">@Model.ShortDescription</dd>
                </dl>
            </div>

            <div class="col-12 col-lg-4">
                @if (!string.IsNullOrWhiteSpace(Model.MainImageUrl))
                {
                    <img src="@Model.MainImageUrl" alt="@Model.Title" class="img-fluid rounded-3 border" />
                }
            </div>
        </div>

        <form asp-area="Admin" asp-controller="Products" asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post" class="mt-4">
            @Html.AntiForgeryToken()

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-danger px-4">
                    <i class="bi bi-trash me-1"></i> Delete Product
                </button>
                <a asp-area="Admin" asp-controller="Products" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-dark">
                    Back to Details
                </a>
                <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
