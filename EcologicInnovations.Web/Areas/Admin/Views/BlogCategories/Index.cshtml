@model EcologicInnovations.Web.ViewModels.Admin.BlogCategoryAdminListViewModel

<div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center mb-4">
    <div class="d-flex gap-3 flex-wrap">
        <div class="admin-stat-pill">
            <span class="admin-stat-pill-label">Total</span>
            <strong>@Model.TotalCount</strong>
        </div>
        <div class="admin-stat-pill">
            <span class="admin-stat-pill-label">Active</span>
            <strong>@Model.ActiveCount</strong>
        </div>
    </div>

    <a asp-area="Admin" asp-controller="BlogCategories" asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i> Create Category
    </a>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4">
        <form method="get" class="row g-3">
            <div class="col-lg-4">
                <label class="form-label fw-semibold">Search</label>
                <input type="text" name="searchTerm" value="@Model.Filter.SearchTerm" class="form-control" placeholder="Search by name, slug, description" />
            </div>

            <div class="col-lg-2">
                <label class="form-label fw-semibold">Active</label>
                <select name="isActive" class="form-select">
                    <option value="">All</option>
                    <option value="true" selected="@(Model.Filter.IsActive == true)">Active</option>
                    <option value="false" selected="@(Model.Filter.IsActive == false)">Inactive</option>
                </select>
            </div>

            <div class="col-lg-3">
                <label class="form-label fw-semibold">Sort By</label>
                <select name="sortBy" class="form-select">
                    <option value="sort_asc" selected="@(Model.Filter.SortBy == "sort_asc")">Sort Order (Asc)</option>
                    <option value="sort_desc" selected="@(Model.Filter.SortBy == "sort_desc")">Sort Order (Desc)</option>
                    <option value="name_asc" selected="@(Model.Filter.SortBy == "name_asc")">Name (A-Z)</option>
                    <option value="name_desc" selected="@(Model.Filter.SortBy == "name_desc")">Name (Z-A)</option>
                    <option value="newest" selected="@(Model.Filter.SortBy == "newest")">Newest</option>
                    <option value="oldest" selected="@(Model.Filter.SortBy == "oldest")">Oldest</option>
                </select>
            </div>

            <div class="col-lg-3">
                <label class="form-label fw-semibold">Page Size</label>
                <select name="pageSize" class="form-select">
                    <option value="10" selected="@(Model.Filter.PageSize == 10)">10</option>
                    <option value="20" selected="@(Model.Filter.PageSize == 20)">20</option>
                    <option value="50" selected="@(Model.Filter.PageSize == 50)">50</option>
                </select>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-funnel me-1"></i> Apply
                </button>
                <a asp-area="Admin" asp-controller="BlogCategories" asp-action="Index" class="btn btn-outline-secondary">
                    Reset
                </a>
            </div>
        </form>
    </div>
</div>

@if (Model.EmptyState is not null)
{
    <partial name="~/Views/Shared/_EmptyStatePartial.cshtml" model="Model.EmptyState" />
}
else
{
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Slug</th>
                        <th>Description</th>
                        <th>Blogs</th>
                        <th>Sort</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="fw-semibold">@item.Name</td>
                        <td><code>@item.Slug</code></td>
                        <td class="text-muted">@((item.Description ?? string.Empty).Length > 80 ? item.Description![..80] + "..." : item.Description)</td>
                        <td>@item.BlogCount</td>
                        <td>@item.SortOrder</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                            }
                        </td>
                        <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-4">
        <partial name="~/Views/Shared/_PaginationPartial.cshtml" model="Model.Pagination" />
    </div>
}
