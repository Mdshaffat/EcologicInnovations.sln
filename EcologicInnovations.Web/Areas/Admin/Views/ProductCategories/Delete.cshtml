@model EcologicInnovations.Web.ViewModels.Admin.ProductCategoryAdminDetailsViewModel

<div class="card border-0 shadow-sm admin-card">
    <div class="card-body p-4">
        <div class="d-flex align-items-start gap-3 mb-4">
            <div class="text-danger fs-2">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <div>
                <h2 class="h4 mb-2">Delete Product Category</h2>
                <p class="text-muted mb-0">
                    Please review the category below before confirming deletion.
                </p>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="border rounded-3 p-3 h-100">
                    <div class="small text-muted mb-1">Category Name</div>
                    <div class="fw-semibold">@Model.Name</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="border rounded-3 p-3 h-100">
                    <div class="small text-muted mb-1">Slug</div>
                    <div><code>@Model.Slug</code></div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="border rounded-3 p-3 h-100">
                    <div class="small text-muted mb-1">Assigned Products</div>
                    <div class="fw-semibold">@Model.ProductCount</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="border rounded-3 p-3 h-100">
                    <div class="small text-muted mb-1">Status</div>
                    <div class="fw-semibold">@(Model.IsActive ? "Active" : "Inactive")</div>
                </div>
            </div>
        </div>

        @if (Model.ProductCount > 0)
        {
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-circle me-2"></i>
                This category cannot be deleted because it currently has assigned products.
                Move or remove the products first, then try again.
            </div>

            <div class="d-flex flex-wrap gap-2">
                <a asp-area="Admin" asp-controller="ProductCategories" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                    Edit Category
                </a>
                <a asp-area="Admin" asp-controller="ProductCategories" asp-action="Index" class="btn btn-outline-secondary">
                    Back to List
                </a>
            </div>
        }
        else
        {
            <form asp-area="Admin" asp-controller="ProductCategories" asp-action="Delete" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()

                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash me-1"></i> Confirm Delete
                    </button>

                    <a asp-area="Admin" asp-controller="ProductCategories" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-dark">
                        Back to Details
                    </a>

                    <a asp-area="Admin" asp-controller="ProductCategories" asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>
                </div>
            </form>
        }
    </div>
</div>
