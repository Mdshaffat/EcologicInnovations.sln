@model EcologicInnovations.Web.ViewModels.Admin.ProductCategoryAdminDetailsViewModel

<link rel="stylesheet" href="~/css/admin-product-categories.css" asp-append-version="true" />

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm admin-card">
            <div class="card-body p-4">
                <div class="d-flex flex-wrap justify-content-between gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">@Model.Name</h2>
                        <div class="text-muted">
                            <code>@Model.Slug</code>
                        </div>
                    </div>

                    <div>
                        @if (Model.IsActive)
                        {
                            <span class="badge text-bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Inactive</span>
                        }
                    </div>
                </div>

                <dl class="row mb-0">
                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model.Description) ? Model.Description : "—")</dd>

                    <dt class="col-sm-3">Sort Order</dt>
                    <dd class="col-sm-9">@Model.SortOrder</dd>

                    <dt class="col-sm-3">Assigned Products</dt>
                    <dd class="col-sm-9">@Model.ProductCount</dd>

                    <dt class="col-sm-3">Created</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</dd>

                    <dt class="col-sm-3">Updated</dt>
                    <dd class="col-sm-9">@(Model.UpdatedAt.HasValue ? Model.UpdatedAt.Value.ToLocalTime().ToString("dd MMM yyyy hh:mm tt") : "Not updated yet")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm admin-card">
            <div class="card-body p-4">
                <h5 class="mb-3">Quick Actions</h5>

                <div class="d-grid gap-2">
                    <a asp-area="Admin" asp-controller="ProductCategories" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="bi bi-pencil-square me-1"></i> Edit Category
                    </a>

                    <a asp-area="Admin" asp-controller="ProductCategories" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i> Delete Category
                    </a>

                    <a asp-area="Admin" asp-controller="ProductCategories" asp-action="Index" class="btn btn-outline-secondary">
                        Back to List
                    </a>
                </div>

                <hr class="my-4" />

                <div class="small text-muted">
                    Categories are used by the public products sidebar filter and by product assignment in the Product admin module.
                </div>
            </div>
        </div>
    </div>
</div>
