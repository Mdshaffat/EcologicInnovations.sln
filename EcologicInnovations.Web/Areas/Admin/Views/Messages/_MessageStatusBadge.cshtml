@model EcologicInnovations.Web.Models.Enums.ContactMessageStatus

@{
    var (cssClass, icon) = Model switch
    {
        EcologicInnovations.Web.Models.Enums.ContactMessageStatus.New => ("text-bg-danger", "bi-envelope-fill"),
        EcologicInnovations.Web.Models.Enums.ContactMessageStatus.Unread => ("text-bg-warning", "bi-envelope-fill"),
        EcologicInnovations.Web.Models.Enums.ContactMessageStatus.Read => ("text-bg-primary", "bi-envelope-open"),
        EcologicInnovations.Web.Models.Enums.ContactMessageStatus.Replied => ("text-bg-success", "bi-reply"),
        EcologicInnovations.Web.Models.Enums.ContactMessageStatus.Closed => ("text-bg-secondary", "bi-check-circle"),
        _ => ("text-bg-light", "bi-question-circle")
    };
}

<span class="badge rounded-pill @cssClass"><i class="bi @icon me-1"></i>@Model</span>
