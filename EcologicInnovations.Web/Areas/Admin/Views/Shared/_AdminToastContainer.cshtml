@using EcologicInnovations.Web.Helpers

@{
    var toasts = TempData.GetUiToasts();
}

@if (toasts.Count > 0)
{
    <div class="toast-container position-fixed top-0 end-0 p-3 ui-toast-container">
        @foreach (var toast in toasts)
        {
            <div class="toast border-0 shadow-sm ui-toast ui-toast-@toast.Type"
                 role="alert"
                 aria-live="assertive"
                 aria-atomic="true"
                 data-bs-autohide="true"
                 data-bs-delay="@toast.Delay">
                <div class="toast-header">
                    <strong class="me-auto">@(!string.IsNullOrWhiteSpace(toast.Title) ? toast.Title : "Notice")</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body">
                    @toast.Message
                </div>
            </div>
        }
    </div>
}
