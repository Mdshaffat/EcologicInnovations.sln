<div class="admin-topbar">
    <div class="d-flex align-items-center justify-content-between gap-3">
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-light admin-sidebar-toggle d-lg-none" id="adminSidebarToggle" aria-label="Toggle navigation">
                <i class="bi bi-list"></i>
            </button>

            <div>
                <span class="admin-topbar-label">Admin Workspace</span>
            </div>
        </div>

        <div class="d-flex align-items-center gap-3">
            <div class="admin-topbar-user text-end">
                <div class="fw-semibold small">@User.Identity?.Name</div>
                <div class="text-muted tiny">Authorized Administrator</div>
            </div>

            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-person-circle me-1"></i> Account
            </a>

            <form asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                  method="post"
                  class="d-inline">
                <button type="submit" class="btn btn-dark btn-sm">
                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                </button>
            </form>
        </div>
    </div>
</div>
